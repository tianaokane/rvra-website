  <style>
    .accessibility-wrap{
      max-width:900px;
      margin:0 auto;
    }

    .accessibility-card{
      background:var(--white);
      border:1px solid var(--border);
      border-radius:var(--radius);
      box-shadow:var(--shadow-sm);
      padding:2rem;
      margin-bottom:1.25rem;
    }

    .accessibility-card h2{
      font-size:1.45rem;
      margin-bottom:.85rem;
      letter-spacing:-.01em;
    }

    .accessibility-card h3{
      font-size:1.05rem;
      margin:1.4rem 0 .5rem;
      color:var(--text);
    }

    .accessibility-card p,
    .accessibility-card li{
      color:var(--text-mid);
      line-height:1.8;
    }

    .accessibility-card ul{
      list-style:disc;
      padding-left:1.4rem;
      margin:.75rem 0 0;
    }

    .accessibility-card li{
      margin-bottom:.45rem;
    }

    .accessibility-meta{
      display:flex;
      align-items:center;
      justify-content:center;
      gap:.7rem;
      flex-wrap:wrap;
      margin-top:1.5rem;
      color:var(--text-mid);
      font-weight:600;
      font-size:.95rem;
    }

    .accessibility-pill{
      display:inline-flex;
      align-items:center;
      gap:.4rem;
      background:var(--white);
      border:1px solid var(--border);
      border-radius:100px;
      padding:.45rem .9rem;
      box-shadow:var(--shadow-sm);
    }

    .accessibility-highlight{
      background:linear-gradient(135deg,var(--green-pale),var(--blue-pale));
      border:1px solid var(--blue-mid);
      border-radius:var(--radius-lg);
      padding:2rem;
      margin-bottom:1.5rem;
      text-align:center;
    }

    .accessibility-highlight p{
      color:var(--text-mid);
      max-width:700px;
      margin:0 auto;
    }

    .accessibility-contact-grid{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:1rem;
      margin-top:1rem;
    }

    .accessibility-contact-item{
      background:var(--off-white);
      border:1px solid var(--border);
      border-radius:var(--radius-sm);
      padding:1rem;
    }

    .accessibility-contact-item strong{
      display:block;
      color:var(--text);
      margin-bottom:.2rem;
    }

    .accessibility-card a{
      color:var(--blue-dark);
      font-weight:700;
      text-decoration:underline;
      text-underline-offset:3px;
    }

    .accessibility-card a:hover{
      color:var(--orange-dark);
    }

    .accessibility-check-grid{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:1rem;
      margin-top:1rem;
    }

    .accessibility-check{
      background:var(--off-white);
      border:1px solid var(--border);
      border-radius:var(--radius-sm);
      padding:1rem;
    }

    .accessibility-check strong{
      display:block;
      color:var(--text);
      margin-bottom:.25rem;
    }

    .accessibility-check p{
      font-size:.95rem;
      margin:0;
    }

    @media(max-width:640px){
      .accessibility-card{padding:1.4rem;}
      .accessibility-contact-grid,
      .accessibility-check-grid{grid-template-columns:1fr;}
    }
  </style>
